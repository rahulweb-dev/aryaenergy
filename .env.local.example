# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ats-india

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# NextAuth Google OAuth provider (optional — Credentials login works without it)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (booking confirmation / contact notification emails — optional in dev)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ATS India <no-reply@atsindia.test>

# ImageKit (admin vehicle photo uploads — optional in dev)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Seed script (bun run seed:admin) — creates the first Super Admin user
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@atsindia.test
ADMIN_SEED_PASSWORD=change-me-immediately
